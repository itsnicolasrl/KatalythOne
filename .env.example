###############################################################################
# Katalyth One - Variables de entorno (ejemplo)
# 
# Nota: no incluyas secretos reales en el repo. Este archivo es solo guía.
###############################################################################

###############################################################################
# Base de datos (OBLIGATORIO)
# 
# Debe apuntar a tu PostgreSQL.
# Ejemplo:
# postgresql://USER:PASSWORD@HOST:5432/DB_NAME?schema=public
###############################################################################
DATABASE_URL="postgresql://USER:PASSWORD@HOST:5432/DB_NAME?schema=public"

###############################################################################
# Auth (OBLIGATORIO)
###############################################################################

# Secreto para firmar JWT.
# Debe ser un string largo y aleatorio (mínimo ~32 caracteres).
AUTH_JWT_SECRET="PON_AQUI_UN_SECRETO_LARGO_Y_ALEATORIO"

# Expiración del access token.
AUTH_JWT_EXPIRES_IN=15m

# Nombres de cookies (HTTP-only en runtime).
AUTH_COOKIE_NAME=katalyth_token
AUTH_REFRESH_COOKIE_NAME=katalyth_refresh_token

# Expiración del refresh token.
AUTH_REFRESH_EXPIRES_IN=30d

# En producción (HTTPS) recomendado: true.
# En desarrollo local (HTTP) suele ser false.
AUTH_COOKIE_SECURE=false

###############################################################################
# CSRF / Origen permitido (OBLIGATORIO para producción)
#
# IMPORTANTE:
# Debe coincidir con el dominio/origen desde donde se originan las requests
# del navegador (mismo host y protocolo).
#
# Ejemplos:
# - Local:  http://localhost:3000
# - Vercel: https://tu-dominio.vercel.app
###############################################################################
APP_BASE_URL="http://localhost:3000"

###############################################################################
# Facturación interna por tarjeta (sin proveedor externo)
#
# Los cambios de plan se gestionan directamente en la aplicación.
###############################################################################
BILLING_SIMULATED_MODE=true

###############################################################################
# Limpieza de cuentas programadas (opcional pero recomendado)
#
# Se usa para proteger /api/account/delete/cleanup (cron interno).
###############################################################################
ACCOUNT_DELETION_CRON_SECRET="pon_un_secreto_fuerte_para_cron"

